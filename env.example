# ============================================================
# Sistema RAG • Bastos & Luz — Variáveis de Ambiente
# ============================================================
# Copie para .env e preencha. NUNCA commite o .env real.
# Em produção: chmod 600 .env
# ============================================================

# ---------- Aplicação ----------
NODE_ENV=production
PORT=5000
# URL pública do dashboard (sem barra final)
PUBLIC_URL=https://portal.bastoseluz.com.br

# ---------- Banco de Dados ----------
# Postgres com extensões pgvector, pg_trgm e unaccent já habilitadas
DATABASE_URL="postgresql://saas_admin:TROCAR_SENHA_FORTE@localhost:5432/saas_financeiro"

# Usado SOMENTE pelo script de backup (scripts/backup.sh)
DB_PASSWORD=TROCAR_SENHA_FORTE

# ---------- Autenticação ----------
# Gere uma chave forte: openssl rand -hex 64
JWT_SECRET=COLE_AQUI_O_RESULTADO_DE_openssl_rand_hex_64
JWT_EXPIRES_IN=2h
REFRESH_TOKEN_EXPIRES_IN=14d

# Cookies (em desenvolvimento local, COOKIE_SECURE=false)
COOKIE_SECURE=true
COOKIE_SAMESITE=strict

# ---------- Google Cloud (Drive + Vision) ----------
# Caminho absoluto para o JSON da Service Account
# IMPORTANTE: arquivo precisa estar com chmod 600
GOOGLE_APPLICATION_CREDENTIALS=/root/saas_financeiro/secrets/gcp-sa.json

# ID da pasta-raiz "Clientes" no Drive
# Pegue da URL: https://drive.google.com/drive/folders/AQUI_ESTA_O_ID
GOOGLE_DRIVE_ROOT_FOLDER_ID=

# ---------- Gemini (API Key, NÃO Service Account) ----------
# Gere em: https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
EMBEDDING_MODEL=text-embedding-004

# ---------- WhatsApp ----------
# Números autorizados (E.164 sem o "+"), separados por vírgula
# Exemplo: 5592991110000,5592991110001
WHATSAPP_WHITELIST=

# ---------- Backup ----------
# Arquivo com a passphrase do GPG (chmod 600)
# Gere: openssl rand -base64 48 > /root/.backup_key && chmod 600 /root/.backup_key
BACKUP_GPG_PASSPHRASE_FILE=/root/.backup_key

# Remote configurado no rclone (rclone config)
# Sugestão: Backblaze B2 ou Cloudflare R2
BACKUP_REMOTE=b2:bastosluz-backups

# Webhook opcional para alerta de falha de backup (Slack, Discord, etc.)
ALERT_WEBHOOK=
